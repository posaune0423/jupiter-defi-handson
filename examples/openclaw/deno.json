{
  "lock": {
    "path": "./deno.lock",
    "frozen": true
  },
  "minimumDependencyAge": "P7D",
  "allowScripts": false,
  "tasks": {
    "wallet": "dotenvx run -f .env.encrypted --strict -- deno run --allow-env=JUPITER_API_KEY,PRIVATE_KEY,SOLANA_RPC_URL,WS_NO_BUFFER_UTIL,WS_NO_UTF_8_VALIDATE --allow-net scripts/check-wallet.ts",
    "swap": "dotenvx run -f .env.encrypted --strict -- deno run --allow-env=JUPITER_API_KEY,PRIVATE_KEY,SOLANA_RPC_URL,WS_NO_BUFFER_UTIL,WS_NO_UTF_8_VALIDATE --allow-net scripts/swap.ts",
    "swap:execute": "dotenvx run -f .env.encrypted --strict -- deno run --allow-env=JUPITER_API_KEY,PRIVATE_KEY,SOLANA_RPC_URL,WS_NO_BUFFER_UTIL,WS_NO_UTF_8_VALIDATE --allow-net scripts/swap.ts --execute",
    "lend": "dotenvx run -f .env.encrypted --strict -- deno run --allow-env=JUPITER_API_KEY,PRIVATE_KEY,SOLANA_RPC_URL,WS_NO_BUFFER_UTIL,WS_NO_UTF_8_VALIDATE --allow-net scripts/lend.ts",
    "lend:execute": "dotenvx run -f .env.encrypted --strict -- deno run --allow-env=JUPITER_API_KEY,PRIVATE_KEY,SOLANA_RPC_URL,WS_NO_BUFFER_UTIL,WS_NO_UTF_8_VALIDATE --allow-net scripts/lend.ts --execute",
    "dca": "dotenvx run -f .env.encrypted --strict -- deno run --allow-env=JUPITER_API_KEY,PRIVATE_KEY,SOLANA_RPC_URL,WS_NO_BUFFER_UTIL,WS_NO_UTF_8_VALIDATE --allow-net scripts/dca.ts",
    "dca:execute": "dotenvx run -f .env.encrypted --strict -- deno run --allow-env=JUPITER_API_KEY,PRIVATE_KEY,SOLANA_RPC_URL,WS_NO_BUFFER_UTIL,WS_NO_UTF_8_VALIDATE --allow-net scripts/dca.ts --execute",
    "report": "dotenvx run -f .env.encrypted --strict -- deno run --allow-env=JUPITER_API_KEY,PRIVATE_KEY,SOLANA_RPC_URL,WS_NO_BUFFER_UTIL,WS_NO_UTF_8_VALIDATE --allow-net scripts/position-report.ts",
    "fmt:check": "deno fmt --check scripts src deno.json",
    "lint": "deno lint",
    "check": "deno check scripts/*.ts src/commands/*.ts src/config/*.ts src/lib/jupiter/*.ts src/lib/solana/*.ts src/usecases/*/*.ts src/utils/*.ts",
    "test": "deno test --allow-read=. --allow-env=WS_NO_BUFFER_UTIL,WS_NO_UTF_8_VALIDATE src/*_test.ts src/commands/*_test.ts src/lib/solana/*_test.ts src/usecases/*/*_test.ts src/utils/*_test.ts"
  },
  "imports": {
    "@solana/kit": "npm:@solana/kit@^6.8.0",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "bs58": "npm:bs58@^6.0.0"
  }
}
